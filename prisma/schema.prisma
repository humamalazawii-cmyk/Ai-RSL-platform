// RSL-AI Platform Database Schema
// Starts with auth + investor tracking, ready to grow with ERP modules

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// INVESTOR TRACKING
// ============================================
model Visitor {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  phone       String?
  company     String?
  ipAddress   String?
  userAgent   String?    @db.Text
  firstVisit  DateTime   @default(now())
  lastVisit   DateTime   @default(now())
  totalVisits Int        @default(1)
  pageViews   PageView[]

  @@index([email])
  @@index([lastVisit])
}

model PageView {
  id              Int      @id @default(autoincrement())
  visitorId       Int
  visitor         Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  path            String
  timestamp       DateTime @default(now())
  durationSeconds Int      @default(0)

  @@index([visitorId])
  @@index([path])
}

// ============================================
// MULTI-TENANT - Organizations
// ============================================
model Organization {
  id              String   @id @default(cuid())
  name            String
  sector          String?
  subSector       String?
  employeeCount   String?
  country         String   @default("IQ")
  baseCurrency    String   @default("IQD")
  accountStandard String   @default("IRAQI")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users          User[]
  accounts       Account[]
  journalEntries JournalEntry[]
}

// ============================================
// USERS & AUTH
// ============================================
model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  name           String
  role           Role          @default(USER)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  lastLogin      DateTime?

  passwordChangedAt   DateTime?
  failedLoginAttempts Int       @default(0)
  lastFailedAttempt   DateTime?
  lockedUntil         DateTime?

  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  mfaBackupCodes String[]  @default([])
  mfaEnforcedAt  DateTime?

  passwordResetTokens PasswordResetToken[]
  authEvents          AuthEvent[]

  @@index([email])
  @@index([organizationId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  MANAGER
  USER
}

// ============================================
// SECURITY: Password Reset Tokens
// ============================================
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  createdIp String?

  @@index([userId])
  @@index([expiresAt])
  @@index([tokenHash])
}

// ============================================
// SECURITY: Auth Events (Audit Log)
// ============================================
model AuthEvent {
  id             String        @id @default(cuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?
  email          String?
  eventType      AuthEventType
  success        Boolean
  ip             String?
  userAgent      String?       @db.Text
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([email])
  @@index([eventType])
  @@index([createdAt])
  @@index([ip])
  @@index([success])
  @@index([organizationId])
}

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  MFA_ENABLED
  MFA_DISABLED
  MFA_CHALLENGE_SUCCESS
  MFA_CHALLENGE_FAILURE
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  SUSPICIOUS_ACTIVITY
  RATE_LIMIT_EXCEEDED
}

// ============================================
// ACCOUNTING - Chart of Accounts
// ============================================
model Account {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  nameAr         String
  nameEn         String?
  type           AccountType
  parentId       String?
  parent         Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]     @relation("AccountHierarchy")
  level          Int           @default(1)
  isActive       Boolean       @default(true)
  currency       String        @default("IQD")
  balance        Decimal       @default(0) @db.Decimal(18, 3)
  createdAt      DateTime      @default(now())
  journalLines   JournalLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// ============================================
// ACCOUNTING - Journal Entries (CJAE Engine)
// ============================================
model JournalEntry {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entryNumber    String
  entryType      String        @default("JV")
  entryDate      DateTime
  description    String?       @db.Text
  status         EntryStatus   @default(DRAFT)
  totalDebit     Decimal       @default(0) @db.Decimal(18, 3)
  totalCredit    Decimal       @default(0) @db.Decimal(18, 3)
  postedAt       DateTime?
  postedBy       String?
  reversalOf     String?
  createdAt      DateTime      @default(now())
  lines          JournalLine[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId])
  @@index([entryDate])
  @@index([status])
}

enum EntryStatus {
  DRAFT
  POSTED
  REVERSED
  REVERSING
}

model JournalLine {
  id           String       @id @default(cuid())
  entryId      String
  entry        JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId    String
  account      Account      @relation(fields: [accountId], references: [id])
  lineNumber   Int
  description  String?
  debit        Decimal      @default(0) @db.Decimal(18, 3)
  credit       Decimal      @default(0) @db.Decimal(18, 3)
  currency     String       @default("IQD")
  exchangeRate Decimal      @default(1) @db.Decimal(18, 6)
  debitBase    Decimal      @default(0) @db.Decimal(18, 3)
  creditBase   Decimal      @default(0) @db.Decimal(18, 3)

  @@index([entryId])
  @@index([accountId])
}

// ============================================
// ENGINES: COE + CJAE + CUOM
// ============================================
model OperationLog {
  id             String   @id @default(cuid())
  organizationId String
  operationType  String
  module         String
  userId         String?
  payload        Json
  status         String
  executedAt     DateTime @default(now())
  durationMs     Int?

  @@index([organizationId])
  @@index([operationType])
  @@index([executedAt])
}

model UoMCategory {
  id       String          @id @default(cuid())
  nameAr   String
  nameEn   String?
  baseUnit String
  units    UnitOfMeasure[]
}

model UnitOfMeasure {
  id             String      @id @default(cuid())
  categoryId     String
  category       UoMCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  code           String      @unique
  nameAr         String
  nameEn         String?
  conversionRate Decimal     @default(1) @db.Decimal(18, 6)
  isBase         Boolean     @default(false)
}

// ============================================
// RSL IDEAS VAULT (Internal tool — Humam + Ali only)
// ============================================
// Meeting recording → Whisper transcription → Claude analysis
// Outputs: summary + action items + roadmap ideas + decisions

model Meeting {
  id              String   @id @default(cuid())
  title           String
  meetingDate     DateTime
  durationMinutes Int?

  // Source
  source      MeetingSource @default(GOOGLE_MEET)
  sourceId    String? // Google Meet ID
  driveFileId String? // Google Drive file ID

  // Files in Cloud Storage
  audioUrl String?
  videoUrl String?

  // Processing
  status           MeetingStatus @default(UPLOADED)
  errorMessage     String?       @db.Text
  detectedLanguage String? // "ar", "en", "mixed"

  // Participants: [{name, email, speakingTimeMs}]
  participants Json?

  // Analysis outputs
  summary String? @db.Text

  // Relations
  transcript  Transcript?
  actionItems ActionItem[]
  ideas       Idea[]
  decisions   Decision[]

  // Audit
  createdBy String // user email
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingDate])
  @@index([status])
  @@index([createdBy])
}

model Transcript {
  id        String  @id @default(cuid())
  meetingId String  @unique
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  fullText String @db.Text
  // Segments: [{speaker, start, end, text, language}]
  segments Json

  whisperModel String   @default("whisper-1")
  createdAt    DateTime @default(now())
}

model ActionItem {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  text     String     @db.Text
  assignee String? // Name or email
  dueDate  DateTime?
  priority Priority   @default(MEDIUM)
  status   TaskStatus @default(OPEN)

  // Source tracking (for verification)
  sourceQuote     String? @db.Text
  sourceTimestamp Int? // Seconds into recording

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([status])
  @@index([assignee])
}

model Idea {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  title       String
  description String       @db.Text
  category    IdeaCategory
  tags        String[]

  // Roadmap integration
  proposedMonth String? // e.g., "Month 2", "Month 3"
  priority      Priority   @default(MEDIUM)
  status        IdeaStatus @default(PROPOSED)

  // Source tracking
  sourceQuote     String? @db.Text
  sourceTimestamp Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId])
  @@index([category])
  @@index([status])
}

model Decision {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  text      String  @db.Text
  decidedBy String? // Who made the decision
  category  String? // TECHNICAL, BUSINESS, STRATEGIC, etc.

  // Source tracking
  sourceQuote     String? @db.Text
  sourceTimestamp Int?

  createdAt DateTime @default(now())

  @@index([meetingId])
}

// ============================================
// VAULT ENUMS
// ============================================

enum MeetingSource {
  GOOGLE_MEET
  MANUAL_UPLOAD
  ZOOM
}

enum MeetingStatus {
  UPLOADED // File received, waiting to process
  TRANSCRIBING // Whisper processing
  ANALYZING // Claude analyzing transcript
  READY // All analysis complete
  FAILED // Something went wrong
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum IdeaCategory {
  FEATURE // New product feature
  BUG // Bug fix
  IMPROVEMENT // Enhancement to existing
  STRATEGIC // Business/market strategy
  ARCHITECTURE // Technical architecture
}

enum IdeaStatus {
  PROPOSED // Just captured
  APPROVED // Accepted for roadmap
  REJECTED // Decided against
  IMPLEMENTED // Already built
}

// ============================================
// OAUTH TOKENS (for Google Drive integration in RSL Vault)
// ============================================
// Stores access + refresh tokens for each user who connects Google Drive.
// Tokens are encrypted at rest (see src/lib/oauth-crypto.ts).
// One row per (userEmail + provider) combination.

model OAuthToken {
  id String @id @default(cuid())

  // Owner
  userEmail String // From RSL-AI session (must be in RSL_INTERNAL_EMAILS)
  provider  OAuthProvider @default(GOOGLE)

  // Encrypted tokens (AES-256-GCM)
  accessToken  String @db.Text // encrypted
  refreshToken String @db.Text // encrypted

  // Token lifecycle
  scope     String // e.g., "https://www.googleapis.com/auth/drive.readonly"
  expiresAt DateTime // access token expiry (refresh before this)
  tokenType String   @default("Bearer")

  // Provider account metadata
  providerEmail String? // Which Google account they connected (e.g., rslai.vault@gmail.com)

  // Audit
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime? // Last time we used this token for API calls

  @@unique([userEmail, provider])
  @@index([userEmail])
  @@index([expiresAt])
}

enum OAuthProvider {
  GOOGLE
  // Future: MICROSOFT, ZOOM, etc.
}
