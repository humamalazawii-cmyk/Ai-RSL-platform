// RSL-AI Platform Database Schema
// Starts with auth + investor tracking, ready to grow with ERP modules

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// INVESTOR TRACKING
// ============================================
model Visitor {
  id           Int         @id @default(autoincrement())
  name         String
  email        String      @unique
  phone        String?
  company      String?
  ipAddress    String?
  userAgent    String?     @db.Text
  firstVisit   DateTime    @default(now())
  lastVisit    DateTime    @default(now())
  totalVisits  Int         @default(1)
  pageViews    PageView[]
  @@index([email])
  @@index([lastVisit])
}

model PageView {
  id              Int       @id @default(autoincrement())
  visitorId       Int
  visitor         Visitor   @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  path            String
  timestamp       DateTime  @default(now())
  durationSeconds Int       @default(0)
  @@index([visitorId])
  @@index([path])
}

// ============================================
// MULTI-TENANT - Organizations
// ============================================
model Organization {
  id              String    @id @default(cuid())
  name            String
  sector          String?
  subSector       String?
  employeeCount   String?
  country         String    @default("IQ")
  baseCurrency    String    @default("IQD")
  accountStandard String    @default("IRAQI") // IRAQI or IFRS
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users           User[]
  accounts        Account[]
  journalEntries  JournalEntry[]
}

// ============================================
// USERS & AUTH
// ============================================
model User {
  id             String       @id @default(cuid())
  email          String       @unique
  passwordHash   String
  name           String
  role           Role         @default(USER)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  lastLogin      DateTime?
  @@index([email])
  @@index([organizationId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  MANAGER
  USER
}

// ============================================
// ACCOUNTING - Chart of Accounts
// ============================================
model Account {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  nameAr         String
  nameEn         String?
  type           AccountType
  parentId       String?
  parent         Account?     @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]    @relation("AccountHierarchy")
  level          Int          @default(1)
  isActive       Boolean      @default(true)
  currency       String       @default("IQD")
  balance        Decimal      @default(0) @db.Decimal(18, 3)
  createdAt      DateTime     @default(now())
  journalLines   JournalLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// ============================================
// ACCOUNTING - Journal Entries (CJAE Engine)
// ============================================
model JournalEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entryNumber    String
  entryType      String       @default("JV") // RV/PV/JV/BD/BW/OE/CL/AJ
  entryDate      DateTime
  description    String?      @db.Text
  status         EntryStatus  @default(DRAFT)
  totalDebit     Decimal      @default(0) @db.Decimal(18, 3)
  totalCredit    Decimal      @default(0) @db.Decimal(18, 3)
  postedAt       DateTime?
  postedBy       String?
  reversalOf     String?
  createdAt      DateTime     @default(now())
  lines          JournalLine[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId])
  @@index([entryDate])
  @@index([status])
}

enum EntryStatus {
  DRAFT
  POSTED
  REVERSED
  REVERSING
}

model JournalLine {
  id             String       @id @default(cuid())
  entryId        String
  entry          JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  lineNumber     Int
  description    String?
  debit          Decimal      @default(0) @db.Decimal(18, 3)
  credit         Decimal      @default(0) @db.Decimal(18, 3)
  currency       String       @default("IQD")
  exchangeRate   Decimal      @default(1) @db.Decimal(18, 6)
  debitBase      Decimal      @default(0) @db.Decimal(18, 3)
  creditBase     Decimal      @default(0) @db.Decimal(18, 3)

  @@index([entryId])
  @@index([accountId])
}

// ============================================
// ENGINES: COE + CJAE + CUOM (schemas for future)
// ============================================
model OperationLog {
  id             String    @id @default(cuid())
  organizationId String
  operationType  String
  module         String
  userId         String?
  payload        Json
  status         String    // PENDING / APPROVED / REJECTED / ROLLED_BACK
  executedAt     DateTime  @default(now())
  durationMs     Int?

  @@index([organizationId])
  @@index([operationType])
  @@index([executedAt])
}

model UoMCategory {
  id          String           @id @default(cuid())
  nameAr      String
  nameEn      String?
  baseUnit    String
  units       UnitOfMeasure[]
}

model UnitOfMeasure {
  id             String      @id @default(cuid())
  categoryId     String
  category       UoMCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  code           String      @unique
  nameAr         String
  nameEn         String?
  conversionRate Decimal     @default(1) @db.Decimal(18, 6)
  isBase         Boolean     @default(false)
}
